# OpenAI API Key (get from https://platform.openai.com/)
OPENAI_API_KEY=your_api_key_here

# Database - PostgreSQL with asyncpg driver (required)
# Example for Neon PostgreSQL with SSL:
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=change-me-to-a-secret-key-that-is-at-least-32-characters-long

# Server
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# Qdrant Cloud (for RAG)
QDRANT_URL=https://xyz-example.eu-central.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# GoWA WhatsApp service (running via docker-compose)
GOWA_BASE_URL=http://localhost:8080
GOWA_DEVICE_ID=your-device-id@s.whatsapp.net
GOWA_WEBHOOK_SECRET=your-webhook-secret

# Frontend API URL (used by web app server actions)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

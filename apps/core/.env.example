# DeepInfra API Key (get from https://deepinfra.com/dashboard)
DEEPINFRA_API_KEY=your_api_key_here

# Database (future - Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=c60c14c814d2624e4d7d6ed02d6019b5864a31d9d71fffb3a80b38247fe36f61

# Server
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# Google OAuth (optional - for SSO)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback/google

# Qdrant Cloud (for RAG)
QDRANT_URL=https://xyz-example.eu-central.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Frontend API URL (used by web app server actions)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
